{
  "manifest_version": 3,
  "name": "SA ChromeOS Customization",
  "version": "0.0.1",
  "description": "SA's ChromeOS customizations",
  "content_scripts": [{
    "matches": ["https://www.cwa.gov.tw/*"],
    "js": ["cwa.js"],
    "run_at": "document_idle"
  }, {
    "matches": ["https://hamivideo.hinet.net/*"],
    "js": ["hamivideo.js"],
    "run_at": "document_idle"
  }, {
    "matches": ["https://term.ptt.cc/*"],
    "js": ["ptt.js"],
    "run_at": "document_end"
  }, {
    "matches": ["https://twpkinfo.com/*"],
    "js": ["twpkinfo.js"],
    "run_at": "document_idle"
  }],
  "web_accessible_resources": [{
      "resources": ["cwa.png"],
      "matches": ["https://www.cwa.gov.tw/*"]
  }, {
      "resources": ["ptt.png"],
      "matches": ["https://term.ptt.cc/*"]
  }, {
      "resources": ["twpkinfo.png"],
      "matches": ["https://twpkinfo.com/*"]
  }]
}
